{
  "$schema": "https://jamdesk.com/docs.json",
  "name": "Kapptivate",
  "description": "Kapptivate product documentation",
  "theme": "nebula",
  "tabsPosition": "top",
  "colors": {
    "primary": "#ED7846",
    "light": "#F4986D",
    "dark": "#D96A3A"
  },
  "background": {
    "decoration": "none",
    "color": {
      "light": "#FFFFFF",
      "dark": "#0D0D0C"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "vitesse-dark",
        "light": "vitesse-light"
      }
    }
  },
  "fonts": {
    "heading": { "family": "Geist" },
    "body": { "family": "Geist" }
  },
  "favicon": "/images/favicon.svg",
  "logo": {
    "light": "/images/logo-dark.svg",
    "dark": "/images/logo-light.svg",
    "href": "/"
  },
  "api": {
    "openapi": [
      "/openapi/example-api.yaml"
    ],
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript",
        "go",
        "ruby",
        "csharp",
        "java",
        "rust",
        "php"
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/introduction"
    }
  },
  "seo": {
    "metatags": {
      "robots": "noindex, nofollow",
      "googlebot": "noindex, nofollow"
    }
  },
  "redirects": [
    {
      "source": "/concepts/core-concepts",
      "destination": "/concepts/workspace"
    },
    {
      "source": "/concepts/channels",
      "destination": "/agents-devices/web-api"
    },
    {
      "source": "/concepts/agents",
      "destination": "/agents-devices/web-api"
    },
    {
      "source": "/concepts/devices-and-statuses",
      "destination": "/agents-devices/statuses"
    },
    {
      "source": "/administration/notifications/availability",
      "destination": "/administration/notifications"
    },
    {
      "source": "/administration/notifications/channels",
      "destination": "/administration/notifications"
    }
  ],
