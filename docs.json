{
  "$schema": "https://jamdesk.com/docs.json",
  "name": "Documentation",
  "description": "Your documentation site powered by Jamdesk",
  "theme": "jam",
  "tabsPosition": "top",
  "colors": {
    "primary": "#635BFF",
    "light": "#7C75FF",
    "dark": "#4F46E5"
  },
  "api": {
    "openapi": [
      "/openapi/example-api.yaml"
    ],
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript",
        "go",
        "ruby",
        "csharp",
        "java",
        "rust",
        "php"
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/introduction"
    }
  },
  "seo": {
    "metatags": {
      "robots": "noindex, nofollow",
      "googlebot": "noindex, nofollow"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Writing Content",
            "icon": "pen",
            "pages": [
              "writing/pages",
              "writing/components",
              "writing/code-blocks"
            ]
          },
          {
            "group": "Components",
            "icon": "puzzle-piece",
            "pages": [
              "components/cards",
              "components/callouts",
              "components/tabs-and-accordions",
              "components/steps"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "icon": "terminal",
        "groups": [
          {
            "group": "CLI Reference",
            "icon": "terminal",
            "pages": [
              "cli/overview",
              "cli/commands",
              "cli/configuration"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "icon": "plug",
        "groups": [
          {
            "group": "API Reference",
            "icon": "plug",
            "pages": [
              {
                "page": "api-reference/openapi-example",
                "title": "OpenAPI Example"
              },
              "api-reference/request-response-examples"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "icon": "compass",
        "groups": [
          {
            "group": "Guides",
            "icon": "compass",
            "pages": [
              "guides/overview",
              "guides/first-integration",
              "guides/ci-cd"
            ]
          }
        ]
      },
      {
        "tab": "Learn",
        "icon": "graduation-cap",
        "groups": [
          {
            "group": "Learn",
            "icon": "graduation-cap",
            "pages": [
              "learn/overview",
              "learn/getting-started",
              "learn/best-practices"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "clock-rotate-left",
        "groups": [
          {
            "group": "Changelog",
            "icon": "clock-rotate-left",
            "pages": [
              "changelog/overview"
            ]
          }
        ]
      }
    ]
  }
}
